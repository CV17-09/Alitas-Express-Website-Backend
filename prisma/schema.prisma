generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Order {
  id              Int      @id @default(autoincrement())
  customerName    String
  phoneNumber     String
  deliveryAddress String
  flavor          String
  quantity        Int
  orderStatus     String   @default("Pending")
  createdAt       DateTime @default(now())
}